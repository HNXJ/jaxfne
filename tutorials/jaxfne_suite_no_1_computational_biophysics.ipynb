   "source": [
    "# Runtime configuration\n",
    "DURATION_MS = 5000.0\n",
    "DT_MS = 0.1\n",
    "SEED = 42\n",
    "DTYPE = \"float32\"\n",
    "\n",
    "# Figure output directory\n",
    "FIG_DIR = Path(\"figures\") / \"suite_no1\"\n",
